<mujoco model="two_agent_ant">
  <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>
  <option timestep="0.02" integrator="RK4"/>
  <default>
    <joint armature="1" damping="1" limited="true"/>
    <geom conaffinity="0" condim="3" density="5.0" friction="1 0.5 0.5" margin="0.01" rgba="0.8 0.6 0.4 1"/>
  </default>

  <worldbody>
    <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="60 60 40" rgba="0.8 0.9 0.8 1" conaffinity="1"/>

    <body name="torso" pos="0 0 0.75">
      <camera name="track" mode="trackcom" pos="0 -3 1" xyaxes="1 0 0 0 0 1"/>
      <geom name="torso_geom" type="sphere" size="0.25" density="5"/>
      <joint name="root" type="free" armature="0" damping="0" limited="false"/>

      <!-- front-right leg (agent: front) -->
      <body name="fr_aux" pos="0 0 0">
        <geom name="fr_aux_geom" type="capsule" fromto="0.0 0.0 0.0 0.2 -0.2 0.0" size="0.08"/>
        <body name="fr_lower" pos="0.2 -0.2 0">
          <joint name="hip_fr" type="hinge" pos="0 0 0" axis="0 0 1" range="-30 30"/>
          <geom name="fr_leg_geom" type="capsule" fromto="0 0 0 0.2 -0.2 0" size="0.08"/>
          <body name="fr_foot" pos="0.2 -0.2 0">
            <joint name="ankle_fr" type="hinge" pos="0 0 0" axis="1 1 0" range="-70 -30"/>
            <geom name="fr_foot_geom" type="capsule" fromto="0 0 0 0.4 -0.4 0" size="0.08"/>
          </body>
        </body>
      </body>

      <!-- front-left leg (agent: front) -->
      <body name="fl_aux" pos="0 0 0">
        <geom name="fl_aux_geom" type="capsule" fromto="0.0 0.0 0.0 0.2 0.2 0.0" size="0.08"/>
        <body name="fl_lower" pos="0.2 0.2 0">
          <joint name="hip_fl" type="hinge" pos="0 0 0" axis="0 0 1" range="-30 30"/>
          <geom name="fl_leg_geom" type="capsule" fromto="0 0 0 0.2 0.2 0" size="0.08"/>
          <body name="fl_foot" pos="0.2 0.2 0">
            <joint name="ankle_fl" type="hinge" pos="0 0 0" axis="-1 1 0" range="30 70"/>
            <geom name="fl_foot_geom" type="capsule" fromto="0 0 0 0.4 0.4 0" size="0.08"/>
          </body>
        </body>
      </body>

      <!-- back-left leg (agent: back) -->
      <body name="bl_aux" pos="0 0 0">
        <geom name="bl_aux_geom" type="capsule" fromto="0.0 0.0 0.0 -0.2 0.2 0.0" size="0.08"/>
        <body name="bl_lower" pos="-0.2 0.2 0">
          <joint name="hip_bl" type="hinge" pos="0 0 0" axis="0 0 1" range="-30 30"/>
          <geom name="bl_leg_geom" type="capsule" fromto="0 0 0 -0.2 0.2 0" size="0.08"/>
          <body name="bl_foot" pos="-0.2 0.2 0">
            <joint name="ankle_bl" type="hinge" pos="0 0 0" axis="1 1 0" range="-70 -30"/>
            <geom name="bl_foot_geom" type="capsule" fromto="0 0 0 -0.4 0.4 0" size="0.08"/>
          </body>
        </body>
      </body>

      <!-- back-right leg (agent: back) -->
      <body name="br_aux" pos="0 0 0">
        <geom name="br_aux_geom" type="capsule" fromto="0.0 0.0 0.0 -0.2 -0.2 0.0" size="0.08"/>
        <body name="br_lower" pos="-0.2 -0.2 0">
          <joint name="hip_br" type="hinge" pos="0 0 0" axis="0 0 1" range="-30 30"/>
          <geom name="br_leg_geom" type="capsule" fromto="0 0 0 -0.2 -0.2 0" size="0.08"/>
          <body name="br_foot" pos="-0.2 -0.2 0">
            <joint name="ankle_br" type="hinge" pos="0 0 0" axis="-1 1 0" range="30 70"/>
            <geom name="br_foot_geom" type="capsule" fromto="0 0 0 -0.4 -0.4 0" size="0.08"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor joint="hip_fr" gear="120" ctrlrange="-1 1" ctrllimited="true"/>
    <motor joint="ankle_fr" gear="120" ctrlrange="-1 1" ctrllimited="true"/>
    <motor joint="hip_fl" gear="120" ctrlrange="-1 1" ctrllimited="true"/>
    <motor joint="ankle_fl" gear="120" ctrlrange="-1 1" ctrllimited="true"/>
    <motor joint="hip_bl" gear="120" ctrlrange="-1 1" ctrllimited="true"/>
    <motor joint="ankle_bl" gear="120" ctrlrange="-1 1" ctrllimited="true"/>
    <motor joint="hip_br" gear="120" ctrlrange="-1 1" ctrllimited="true"/>
    <motor joint="ankle_br" gear="120" ctrlrange="-1 1" ctrllimited="true"/>
  </actuator>
</mujoco>
